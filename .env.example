# AI API Configuration
# For Development (uses 9Router):
ROUTER_API_KEY=your_router_api_key_here
# For Production (uses Google AI Studio Gemini API):
GEMINI_API_KEY=your_google_gemini_api_key_here
# For Direct Anthropic Claude API:
CLAUDE_API_KEY=your_anthropic_claude_api_key_here

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# The public domain of your app in production (e.g., http://lubangkelinci.my.id)
APP_URL=http://your_domain_here

# Database Configuration (Docker Compose)
DB_USER=postgres
DB_PASSWORD=postgres_secure_password_here
DB_NAME=mindmap
